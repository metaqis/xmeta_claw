# 接口名称: 行情分类成交详细统计
# 说明: 根据 `topCode` 查询某个行情分类的成交统计数据，包含总市值、成交量、涨跌分布等。

@baseUrl = https://api.x-metash.cn

### 行情分类成交详细统计
POST {{baseUrl}}/h5/market/censusArchiveTop
Content-Type: application/json

{
  "timeType": 0,
  "topCode": "902698"
}

### 示例响应
# {
#   "code": 200,
#   "msg": "成功",
#   "data": {
#     "totalMarketAmount": 160219540.80,
#     "totalMarketAmountRate": -0.2400,
#     "totalDealCount": 56,
#     "totalDealCountRate": 17.3400,
#     "totalArchiveCount": 71,
#     "upArchiveCount": 5,
#     "downArchiveCount": 23,
#     "upDownList": [
#       { "label": "0-3",  "count": 4,  "type": 1 },
#       { "label": "3-5",  "count": 0,  "type": 1 },
#       { "label": "5-7",  "count": 0,  "type": 1 },
#       { "label": "7-10", "count": 0,  "type": 1 },
#       { "label": ">10%", "count": 1,  "type": 1 },
#       { "label": "0-3",  "count": 18, "type": 2 },
#       { "label": "3-5",  "count": 4,  "type": 2 },
#       { "label": "5-7",  "count": 0,  "type": 2 },
#       { "label": "7-10", "count": 1,  "type": 2 },
#       { "label": ">10%", "count": 0,  "type": 2 }
#     ]
#   }
# }

# 字段说明:
# timeType              — 时间类型，0=今日
# topCode               — 行情分类编码（来自 09_market_top_list 接口的 code 字段）
# totalMarketAmount     — 分类总市值（元）
# totalMarketAmountRate — 总市值涨跌幅（%）
# totalDealCount        — 今日成交数量
# totalDealCountRate    — 成交量涨跌幅（%）
# totalArchiveCount     — 分类内藏品总数
# upArchiveCount        — 今日上涨藏品数
# downArchiveCount      — 今日下跌藏品数
# upDownList            — 涨跌分布列表
#   type=1 为上涨（涨幅区间）
#   type=2 为下跌（跌幅区间）
#   label  — 区间标签，如 "0-3"、"3-5"、"5-7"、"7-10"、">10%"
#   count  — 该区间内藏品数量
