# firstCategory 支持:
# ["WH","YL","YS","CW","TY","PP","KJ","ACG","JQ","AFY","AYX","AYCSJ","QT"]
[{"pageNum":1,"pageSize":20,"firstCategory":"WH"}]

@backendUrl = http://localhost:8000
@token = <token>

### 后端登录(获取 token)
POST {{backendUrl}}/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "admin123"
}

### 通过后端代理获取 SKU 列表
POST {{backendUrl}}/jingtan/sku-wiki-list
Content-Type: application/json
Authorization: Bearer {{token}}

[{"pageNum":1,"pageSize":20,"firstCategory":"WH"}]

### 触发后端入库爬虫(鲸探藏品库 sku wiki)
POST {{backendUrl}}/crawler/jingtan/sku-wiki
Authorization: Bearer {{token}}

### 通过任务系统触发爬取(会写入 task_runs / task_run_logs)
POST {{backendUrl}}/tasks/crawl_jingtan_sku_wiki/run
Authorization: Bearer {{token}}

